# 로컬에서 실행할 때 임의의 랜덤 문자열을 입력하세요.
# 예: AUTH_SECRET=your_random_string_here

# YouTube API
YOUTUBE_API_KEY=

# Database (PostgreSQL)
DATABASE_URL=

# NextAuth Settings
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Supabase Settings
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OAuth - Kakao
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# OAuth - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=