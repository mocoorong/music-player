// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Playlist {
  id     String @id @default(uuid())
  title  String
  songs  Song[]
}

model Song {
  id          String   @id @default(uuid())
  title       String
  youtubeUrl  String
  thumbnail   String
  playlistId  String
  playlist    Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
}